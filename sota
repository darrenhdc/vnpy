#!/usr/bin/env bash
# ./sota — SOTA 快捷操作入口
# 用法:
#   ./sota status         查看当前 SOTA 状态
#   ./sota list           列出所有候选策略
#   ./sota history        查看 SOTA 演化史

PROJECT_ROOT="$(cd "$(dirname "$0")" && pwd)"

# 无参数时默认显示 status
if [ $# -eq 0 ]; then
    python "${PROJECT_ROOT}/scripts/sota.py" status
else
    python "${PROJECT_ROOT}/scripts/sota.py" "$@"
fi
